{
  "connect_db": "sqlite",
  "source": {
    "type": "sqlite",
    "path": "sample_source.db",
    "table": "source_processing",
    "seed_sample_data": true
  },
  "local": {
    "path": "local.db",
    "table": "local_processing"
  },
  "runtime": {
    "python_executable": "C:/Path/To/Python/python.exe"
  },
  "db": {
    "type": "postgresql",
    "host": "localhost",
    "port": 5432,
    "database": "your_database",
    "user": "your_user",
    "password": "your_password",
    "options": {
      "sslmode": "disable",
      "connect_timeout": 10
    }
  }
}
